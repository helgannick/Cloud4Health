# ============================================================================
# Cloud4Health - Git Attributes
# ============================================================================

# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Terraform files
*.tf text eol=lf
*.tfvars text eol=lf
*.hcl text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# JSON
*.json text eol=lf

# Python
*.py text eol=lf

# Dockerfiles
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-compose.yml text eol=lf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary

# Archives
*.7z binary
*.gz binary
*.tar binary
*.zip binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Export ignore (não incluir em releases)
.gitignore export-ignore
.gitattributes export-ignore
.github export-ignore
docs/development export-ignore
